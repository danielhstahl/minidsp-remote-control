# put this file in INSTALL_DIRECTORY/system.d/minidsp.service

[Unit]
After=syslog.target
StartLimitIntervalSec=10
StartLimitBurst=10

[Service]
Type=simple
ExecStart=INSTALL_DIRECTORY/minidsp/minidsprs/minidspd --config INSTALL_DIRECTORY/minidsp/minidsprs/minidsp.toml
Restart=always
RestartSec=1
StandardOutput=journal
StandardError=journal
SyslogIdentifier=minidsp
CPUSchedulingPolicy=fifo
CPUSchedulingPriority=10

[Install]
WantedBy=multi-user.target
